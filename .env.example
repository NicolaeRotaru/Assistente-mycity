# ===========================================
#  CHIAVE SEGRETA — riempi e rinomina in .env.local
#  Questo file resta SOLO sul tuo PC. Mai online.
# ===========================================

# --- ANTHROPIC (il cervello AI) ---
# La stessa chiave che usi gia nel sito MyCity.
# La trovi in: console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# --- GITHUB (per aprire le Pull Request dalla pagina /sviluppo) ---
# La pipeline /sviluppo legge il codice e apre le PR sul repo qui sotto:
# punta al MARKETPLACE vero "mycity" (non a questo assistente).
# Il token deve avere accesso in scrittura (Contents + Pull requests) a quel repo.
# Lo crei in: github.com -> Settings -> Developer settings -> Personal access tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_OWNER=NicolaeRotaru
GITHUB_REPO=mycity
# Branch di base su cui aprire le PR (di solito "main").
GITHUB_DEFAULT_BRANCH=main
